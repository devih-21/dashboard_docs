          "hide": false,
          "rawQuery": true,
          "rawSql": "WITH RECURSIVE\ndbt_job_id as (\n    select id, depend_ons from olap_dev.job_config\n),\nall_raw_ids as (\n  SELECT\n      distinct elem as id\n  FROM olap_dev.job_config jc\n  LEFT JOIN LATERAL jsonb_array_elements_text(\n      CASE\n          WHEN jsonb_typeof(jc.depend_ons) = 'array'\n          THEN jc.depend_ons\n          ELSE '[]'::jsonb\n      END\n  ) AS elem ON TRUE\n  where elem not in (select id from dbt_job_id)\n),\nall_config_ids as (\n    select id, '[]'::jsonb AS depend_ons from all_raw_ids\n    union all\n    select id, depend_ons from dbt_job_id\n),\ndownstream AS (\n    -- level 0: job gốc\n    SELECT \n        id,\n        0 AS level\n    FROM all_config_ids\n    WHERE ('All' IN ($job_id) OR id IN ($job_id))\n\n    UNION ALL\n\n    -- downstream level n\n    SELECT \n        c.id,\n        d.level + 1 AS level\n    FROM all_config_ids c\n    JOIN downstream d \n        ON c.depend_ons ? d.id\n    WHERE d.level < $level\n),\nupstream AS (\n    -- level 0: job gốc\n    SELECT \n        id,\n        depend_ons,\n        0 AS level\n    FROM all_config_ids\n    WHERE ('All' IN ($job_id) OR id IN ($job_id))\n\n    UNION ALL\n\n    -- upstream level n\n    SELECT \n        c.id,\n        c.depend_ons,\n        u.level + 1 AS level\n    FROM all_config_ids c\n    JOIN upstream u \n        ON u.depend_ons ? c.id\n    WHERE u.level < $level\n),\nall_ids AS (\n    -- filter theo level\n    SELECT id FROM downstream WHERE level <= $level\n    UNION\n    SELECT id FROM upstream WHERE level <= $level\n)\nSELECT \n    parent_id || '->' || child_id AS id,\n    parent_id AS source,\n    child_id AS target\nFROM (\n    SELECT \n        jsonb_array_elements_text(\n            CASE \n                WHEN jsonb_typeof(depend_ons) = 'array' \n                THEN depend_ons \n                ELSE '[]'::jsonb \n            END\n        ) AS parent_id,\n        id AS child_id\n    FROM all_config_ids\n) all_links\nWHERE parent_id IN (SELECT id FROM all_ids)\n  AND child_id IN (SELECT id FROM all_ids);\n",
